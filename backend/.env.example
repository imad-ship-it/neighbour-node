# Copy to .env and fill in real values. Never commit .env.

SECRET_KEY=change-me
DEBUG=True
# Comma-separated. Only read by prod settings; dev allows all hosts.
ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated. Only read by prod settings; dev allows all origins.
CORS_ALLOWED_ORIGINS=

# GeoDjango toggle (MASTER_PLAN §8.3).
# false = plain postgres engine, no GDAL/PostGIS needed (Windows-friendly).
# true  = PostGIS engine; requires PostGIS extension + GDAL/GEOS installed.
USE_GIS=false

# Dev-only escape hatch: set to sqlite3 to skip Postgres entirely
# (uses backend/db.sqlite3; requires USE_GIS=false). Leave blank for Postgres.
DB_ENGINE=

# PostgreSQL (+ PostGIS when USE_GIS=true)
DB_NAME=neighbor_node
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432
